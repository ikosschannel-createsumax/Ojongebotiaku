{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile with mining progress, role, and balances",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "passwordHash": { "type": "string" },
        "username": { "type": "string" },
        "minerTag": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string" },
        "level": { "type": "number" },
        "experience": { "type": "number" },
        "ldrBalance": { "type": "number" },
        "rupiahBalance": { "type": "number" },
        "highScore": { "type": "number" },
        "registeredAt": { "type": "string" }
      },
      "required": ["email", "username"]
    },
    "deposit_request": {
      "title": "Deposit Request",
      "description": "Pending and completed deposit requests from users waiting for admin approval",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "email", "username", "amount", "method", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Active user accounts with level and balances"
    },
    "/deposit_requests/{requestId}": {
      "schema": "deposit_request",
      "description": "Deposit requests processed by SYSTEM/CS and verified by Admin"
    }
  }
}
